# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your-bot-token-here

# Your application's client (application) ID
DISCORD_CLIENT_ID=your-application-id-here

# Optional: register slash commands instantly to a single guild (server) for testing.
# Leave empty to register commands globally (can take up to ~1 hour to appear).
DISCORD_GUILD_ID=

# Optional defaults for the DisplayCatalog queries
DEFAULT_MARKET=US
DEFAULT_LANGUAGE=en-us
